{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug videocut (MinGW)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\build\\videocut.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "C:/Qt/6.9.0/mingw_64/bin;C:/Qt/Tools/mingw1310_64/bin;${env:PATH}"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/Qt/Tools/mingw1310_64/bin/gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build (Debug)"
    }
  ]
}
